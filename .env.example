# Copy this file to .env and fill in your values. .env is gitignored so it
# never gets committed.

# REQUIRED: Path to the folder containing your server's .log.gz and latest.log files.
MC_LOGS_DIR=C:\path\to\your\server\logs

# Optional: only needed if you want to push the generated site to GitHub. Use a GitHub personal access token (repo scope):
# GIT_TOKEN=PAT-HERE

# Optional: only needed if this machine isn't already a git clone with push
# access configured. Use a GitHub personal access token (repo scope):
# MC_REPO=https://<token>@github.com/ChristopherSnay/minecraft-log-visualizer.git

# Optional overrides:
# MC_SITE_DIR=./site
# MC_BRANCH=gh-pages
