# Copy this file to .env and fill in your values. .env is gitignored so it
# never gets committed.

# REQUIRED: Path to your Minecraft server root directory. The world folder, logs,
# and usercache.json are all derived from this path.
MC_ROOT=C:\path\to\your\server

# Comma-separated keys to exclude from the generated stats.json to reduce file size.
# Top-level keys: deltas, level, logs, usercache
# Per-player keys: inventory, effects, position, dimension, xp, health, food,
#   saturation, completed, in_progress
# Prefix with @ to exclude an entire player by name (e.g. @PersonUsername)
# EXCLUDE_DATA=deltas,in_progress,@PersonUsername
