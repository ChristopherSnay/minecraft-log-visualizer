# Copy this file to .env and fill in your values. .env is gitignored so it
# never gets committed.

# Path to the folder containing your server's .log.gz and latest.log files.
MC_LOGS_DIR=C:\path\to\your\server\logs

# Optional: only needed if this machine isn't already a git clone with push
# access configured. Use a GitHub personal access token (repo scope):
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# MC_REPO_SLUG=ChristopherSnay/minecraft-log-visualizer

# Optional overrides:
# MC_SITE_DIR=./site
# MC_BRANCH=gh-pages
